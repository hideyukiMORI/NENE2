{
  "name": "nene2-frontend",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <25",
    "npm": ">=10 <12"
  },
  "packageManager": "npm@10.9.7",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:css": "stylelint \"src/**/*.css\"",
    "check:themes": "nene2-tokens validate src/shared/ui/theme/themes/default.css",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "gen:entity": "plop --plopfile plopfile.mjs entity",
    "gen:feature": "plop --plopfile plopfile.mjs feature",
    "gen:page": "plop --plopfile plopfile.mjs page",
    "gen:api-schema": "openapi-typescript ../docs/openapi/openapi.yaml -o src/shared/api/schema.gen.ts",
    "conformance": "nene2-check conformance",
    "check": "npm run type-check && npm run lint && npm run lint:css && npm run check:themes && npm run format && npm run test"
  },
  "dependencies": {
    "@hideyukimori/nene2-client": "^1.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.65.0",
    "react-router": "^7.12.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@hideyukimori/nene2-standards": "^1.1.0",
    "@hideyukimori/nene2-tokens": "^1.0.1",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/vite": "^4.1.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "jsdom": "^29.1.1",
    "msw": "^2.12.4",
    "openapi-typescript": "^7.10.1",
    "plop": "^4.0.5",
    "prettier": "^3.9.4",
    "stylelint": "^17.14.1",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
