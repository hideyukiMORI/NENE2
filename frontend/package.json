{
  "name": "nene2-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <25",
    "npm": ">=10 <12"
  },
  "packageManager": "npm@10.9.7",
  "scripts": {
    "dev": "vite",
