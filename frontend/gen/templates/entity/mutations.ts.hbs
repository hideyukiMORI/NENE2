export function useCreate{{pascalCase noun}}(): UseMutationResult<
  {{pascalCase noun}},
  AppError
> {
  const queryClient = useQueryClient();
  return useMutation({
    mutationFn: async (input: unknown) => {
      const dto = await apiClient.post<{{pascalCase noun}}Dto>(
        '/api/v1/{{plural (kebabCase noun)}}',
        input,
      );
      return map{{pascalCase noun}}DtoToModel(dto);
    },
    onSuccess: async () => {
      await queryClient.invalidateQueries({ queryKey: {{camelCase noun}}Keys.lists() });
