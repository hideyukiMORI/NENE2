{
  "name": "hideyukimori/nene2",
  "description": "PHP micro-framework: JSON APIs first, minimal server HTML, easy React/Vue SPA integration, structure friendly to AI tooling.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.4.1 <9.0",
    "nyholm/psr7": "^1.8",
    "nyholm/psr7-server": "^1.1",
    "psr/container": "^2.0",
    "psr/http-server-handler": "^1.0",
    "psr/http-server-middleware": "^1.0",
    "psr/log": "^3.0",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "psr-4": {
      "Nene2\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Nene2\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse",
    "cs": "php-cs-fixer fix --dry-run --diff --config=.php-cs-fixer.php",
    "cs:fix": "php-cs-fixer fix --config=.php-cs-fixer.php",
    "openapi": "php tools/validate-openapi.php",
    "migrations:status": "phinx status -c phinx.php",
    "migrations:migrate": "phinx migrate -c phinx.php",
    "migrations:rollback": "phinx rollback -c phinx.php",
    "migrations:seed": "phinx seed:run -c phinx.php",
    "check": [
      "@test",
      "@analyse",
      "@cs",
      "@openapi"
    ]
  },
  "config": {
    "sort-packages": true
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.95",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^13.1",
    "robmorgan/phinx": "^0.16.11",
    "symfony/yaml": "^8.0"
  }
}
