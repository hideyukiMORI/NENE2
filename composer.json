{
  "name": "hideyukimori/nene2",
  "description": "PHP micro-framework: JSON APIs first, minimal server HTML, easy React/Vue SPA integration, structure friendly to AI tooling.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.4.1 <9.0"
  },
  "autoload": {
    "psr-4": {
      "Nene2\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Nene2\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse",
    "check": [
      "@test",
      "@analyse"
    ]
  },
  "config": {
    "sort-packages": true
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^13.1"
  }
}
